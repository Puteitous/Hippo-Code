llm:
  provider: dashscope
  api_key: ${DASHSCOPE_API_KEY:-your-api-key-here}
  model: your-model
  base_url: https://dashscope.aliyuncs.com
  max_tokens: 2048
  temperature: 0.7
  timeout: 60000

tools:
  bash:
    enabled: true
    whitelist:
      - git
      - mvn
      - npm
      - docker
      - ls
      - cat
      - grep
      - find
    require_confirmation: true
  file:
    enabled: true
    allowed_paths:
      - .
    max_file_size: 10MB
    blocked_extensions:
      - .env
      - .pem
      - .key
      - .p12
      - .jks

session:
  auto_save: true
  max_history: 50
  history_file: .agent_history

ui:
  theme: dark
  prompt: "agent>"
  syntax_highlight: true
  show_token_usage: true
  show_timestamp: false
  color_output: true

context:
  max_tokens: 30000
  max_messages: 20
  keep_recent_turns: 6
  tool_result:
    max_tokens: 2000
    truncate_strategy: tail

intent:
  enabled: true
  recognition:
    mode: hybrid                    # hybrid | rule | llm
    llm_enabled: true               # 是否启用 LLM 意图识别
    prefer_llm: false               # 是否优先使用 LLM
    high_confidence_threshold: 0.85 # 高置信度阈值
    low_confidence_threshold: 0.50  # 低置信度阈值
    fallback_to_rules: true         # 失败时回退到规则
  
  planning:
    mode: composite                 # composite | simple | llm
    prefer_llm: false               # 是否优先使用 LLM 规划
    high_confidence_threshold: 0.85 # 高置信度阈值
    low_confidence_threshold: 0.50  # 低置信度阈值
    enable_complex_intent_detection: true  # 启用复杂意图检测
